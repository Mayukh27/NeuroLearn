# ============================================================
# .env — Backend Configuration
# ============================================================

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# ML Models
WHISPER_MODEL_SIZE=base
ATTENTION_MODEL_CONFIDENCE_THRESHOLD=0.6
FLAN_T5_MODEL=google/flan-t5-base

# LLM API (optional — for cloud-based question generation)
LLM_API_KEY=your-api-key-here
LLM_API_URL=https://api.anthropic.com/v1/messages

# Database (TinyDB for dev, replace with PostgreSQL URL for prod)
DB_PATH=./data/neurolearn_db.json

# JWT (for future auth)
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Email / SMTP (for Report Card emailing)
# For Gmail: Enable 2FA → create App Password at https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password-here
SMTP_FROM_NAME=NeuroLearn
